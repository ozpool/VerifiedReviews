# VerifiedReviews — web environment variables
# Copy to .env.local and fill in values before running locally.

# Base URL of the Express API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000

# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
# If left empty, only the injected (MetaMask/browser) connector is available.
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional custom RPC for Arbitrum Sepolia (falls back to the public viem endpoint)
NEXT_PUBLIC_RPC_URL=

# Deployed contract addresses (filled in after PR #5 deploy)
NEXT_PUBLIC_SBT_ADDRESS=
NEXT_PUBLIC_REGISTRY_ADDRESS=

# Public app URL — used for Open Graph metadataBase (default: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
