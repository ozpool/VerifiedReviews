# Copy to .env for local dev. .env is gitignored.

NODE_ENV=development
PORT=4000

# MongoDB connection string (local mongod or Atlas). Tests use an ephemeral
# in-memory server and ignore this.
MONGO_URI=mongodb://127.0.0.1:27017/verified-reviews

# Secret used to sign staff/admin/owner JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Domain SIWE login messages must be bound to (your frontend host).
APP_DOMAIN=localhost

# Master mnemonic for deriving per-business minter wallets (crown-jewel secret).
# Generate a fresh one; fund derived addresses with Sepolia ETH only.
MINTER_MNEMONIC=

# Per-customer visit cap: at most this many mints to the same customer at one
# business within the window below (default 2 per 24h). Anti-abuse, not the gate.
CUSTOMER_MINT_DAILY_MAX=2
CUSTOMER_MINT_WINDOW_SEC=86400

# Privy credentials for verifying embedded-wallet (Google/email) logins.
# From the Privy dashboard (https://dashboard.privy.io). The secret is a
# crown-jewel server secret: never commit it or send it to the browser.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Used only by `pnpm -F @vr/api seed:admin` to create the first admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Gas-tank wallet — a server account holding FREE Arbitrum Sepolia testnet ETH.
# At mint time the API sends a tiny top-up to the customer so their embedded
# wallet can pay its own (free, testnet) gas when reviewing — they never fund
# anything and see no fee. Leave blank to disable (then customers must already
# hold gas). Fund the address from a Sepolia faucet. Testnet only — never put a
# real-money key here.
GAS_TANK_PRIVATE_KEY=
# Amount sent per top-up, in ETH (a couple of review submits' worth).
GAS_TANK_TOPUP_ETH=0.0005
# Skip the top-up when the customer already holds at least this much ETH.
GAS_TANK_MIN_BALANCE_ETH=0.0003

# Minter gas funding — the admin/treasury wallet (ADMIN_PRIVATE_KEY) keeps each
# business's minter funded so staff never hit an out-of-gas mint. Funded
# automatically at approval and refilled on a schedule; needs ADMIN_PRIVATE_KEY +
# RPC_URL set, else it's a no-op (fund minters by hand). Testnet ETH = free.
# Amount sent per minter top-up (covers thousands of mints):
MINTER_FUND_AMOUNT_ETH=0.02
# Only top up a minter when it drops below this balance.
MINTER_MIN_BALANCE_ETH=0.005
# How often the background refiller sweeps all minters (ms). Default 1 hour.
MINTER_REFILL_POLL_MS=3600000
