# Arbitrum Sepolia deployment (PR #5). Copy to .env and fill in.
# .env is gitignored — never commit a real key.

# RPC endpoint (defaults to the public Arbitrum Sepolia RPC if unset)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deployer / admin wallet private key. This wallet becomes the SBT admin and
# is the crown-jewel secret of the system — keep it funded with Sepolia ETH only.
PRIVATE_KEY=

# For `pnpm -F @vr/contracts verify` (contract source verification on Arbiscan)
ARBISCAN_API_KEY=
